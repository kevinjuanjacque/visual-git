{
  "name": "gitvisual",
  "version": "1.0.0",
  "description": "Visual Git client with GitHub integration — like GitKraken",
  "main": "out/main/index.js",
  "author": "",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "simple-git": "^3.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.31",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.gitvisual.app",
    "productName": "GitVisual",
    "protocols": [
      {
        "name": "gitvisual",
        "schemes": ["gitvisual"]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "build/icon.png",
      "identity": null
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
